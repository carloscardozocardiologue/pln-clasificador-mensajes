# Copia este archivo como .env y rellena los valores reales
# Railway MySQL: copia la variable DATABASE_URL desde el plugin MySQL de Railway

DATABASE_URL=mysql://usuario:contraseña@host:3306/nombre_db

# Opcional: deshabilitar BETO si el servidor tiene poca RAM (< 2GB)
BETO_ENABLED=true

# Puerto local (Railway lo asigna automáticamente)
PORT=8000
